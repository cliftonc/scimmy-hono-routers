{
  "name": "scimmy-hono-routers",
  "description": "SCIMMY Hono Routers — SCIM 2.0 server middleware for Hono",
  "version": "0.1.0",
  "author": "cliftonc",
  "license": "MIT",
  "type": "module",
  "engines": {
    "node": ">=24"
  },
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    "import": {
      "types": "./dist/index.d.ts",
      "default": "./dist/index.js"
    }
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "files": [
    "dist/**"
  ],
  "keywords": [
    "SCIM",
    "SCIM2",
    "hono",
    "provisioning",
    "identity",
    "rfc7643",
    "rfc7644",
    "scimmy"
  ],
  "homepage": "https://github.com/cliftonc/scimmy-hono-routers#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/cliftonc/scimmy-hono-routers.git"
  },
  "bugs": {
    "url": "https://github.com/cliftonc/scimmy-hono-routers/issues"
  },
  "peerDependencies": {
    "hono": ">=4.0.0",
    "scimmy": "1.x"
  },
  "devDependencies": {
    "@types/sinon": "^21.0.0",
    "hono": "^4.7.0",
    "scimmy": "^1.3.5",
    "sinon": "^21.0.3",
    "tsup": "^8.0.0",
    "typescript": "^5.7.0",
    "vitest": "^3.0.0"
  }
}
